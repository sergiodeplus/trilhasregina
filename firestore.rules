rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras Gerais: Público pode ler, mas apenas Admin (autenticado) pode escrever
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Coleções Específicas (Opcional: Refinamento)
    match /activities/{activity} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /links/{link} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /students/{student} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
  }
}
