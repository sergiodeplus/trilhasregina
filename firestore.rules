rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Qualquer pessoa pode LER (ver o site)
      allow read: if true;
      
      // Apenas usuários logados (Admin) podem ESCREVER (criar/editar/apagar)
      allow write: if request.auth != null;
    }
  }
}
